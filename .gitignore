# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/apps/service/.bundle

# Ignore all environment files.
/apps/service/.env*

# Ignore all logfiles and tempfiles.
/apps/service/log/*
/apps/service/tmp/*
!/apps/service/log/.keep
!/apps/service/tmp/.keep

# Ignore pidfiles, but keep the directory.
/apps/service/tmp/pids/*
!/apps/service/tmp/pids/
!/apps/service/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/apps/service/storage/*
!/apps/service/storage/.keep
/apps/service/tmp/storage/*
!/apps/service/tmp/storage/
!/apps/service/tmp/storage/.keep

# Ignore key files for decrypting credentials and more.
/apps/service/config/*.key

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/apps/web/node_modules
/apps/web/.pnp
/apps/web/.pnp.*
/apps/web/.yarn/*
!apps/web/.yarn/patches
!apps/web/.yarn/plugins
!apps/web/.yarn/releases
!apps/web/.yarn/versions

# testing
/apps/web/coverage

# next.js
/apps/web/.next/
/apps/web/out/

# production
/apps/web/build

# misc
apps/web/.DS_Store
apps/web/*.pem

# debug
apps/web/npm-debug.log*
apps/web/yarn-debug.log*
apps/web/yarn-error.log*
apps/web/.pnpm-debug.log*

# env files (can opt-in for committing if needed)
apps/web/.env*

# vercel
apps/web/.vercel

# typescript
apps/web/*.tsbuildinfo
apps/web/next-env.d.ts

